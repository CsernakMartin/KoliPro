<Window
    x:Class="KoliPro.PortasWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:KoliPro"
    Title="KoliPro - Portás Irányítópult">

    <Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Background="{ThemeResource SystemControlBackgroundAccentBrush}" Padding="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                <Button x:Name="BackButton" Click="BackToDashboard_Click" Visibility="Collapsed" 
                        Margin="0,0,15,0" Background="Transparent" BorderThickness="0">
                    <FontIcon Glyph="&#xE72B;" Foreground="White"/>
                </Button>
                <TextBlock Text="Bejelentkezve: Portás | " Foreground="White" Opacity="0.8" FontSize="16"/>
                <TextBlock x:Name="ClockTextBlock" Foreground="White" Opacity="1" FontSize="16" FontWeight="SemiBold"/>
            </StackPanel>

            <Button Grid.Column="1" Content="Kijelentkezés" Click="Logout_Click" 
                    Background="Transparent" Foreground="White" BorderThickness="0"
                    VerticalAlignment="Center" HorizontalAlignment="Right"/>
        </Grid>
        
        <Grid x:Name="DashboardGrid" Grid.Row="1" Padding="40" Visibility="Visible">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" Click="OpenGuestManagement_Click" 
                    HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Margin="10"
                    Background="{ThemeResource SystemControlBackgroundAltHighBrush}" CornerRadius="12">
                <StackPanel Spacing="15">
                    <FontIcon Glyph="&#xE716;" FontSize="50" Foreground="{ThemeResource SystemAccentColor}"/>
                    <TextBlock Text="Vendég felvétele" FontSize="18" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                    <TextBlock Text="Látogatók rögzítése és keresése" FontSize="12" Foreground="Gray" TextWrapping="Wrap" TextAlignment="Center"/>
                </StackPanel>
            </Button>

            <Button Grid.Column="1" Click="KeyIssuance_Click"
                    HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Margin="10"
                    Background="{ThemeResource SystemControlBackgroundAltHighBrush}" CornerRadius="12">
                <StackPanel Spacing="15">
                    <FontIcon Glyph="&#xE8D7;" FontSize="50" Foreground="Orange"/>
                    <TextBlock Text="Kulcs kiadása" FontSize="18" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                    <TextBlock Text="Szabadidő terem kulcsok" FontSize="12" Foreground="Gray" TextWrapping="Wrap" TextAlignment="Center"/>
                </StackPanel>
            </Button>

            <Button Grid.Column="2" Click="ReportResident_Click"
                    HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Margin="10"
                    Background="{ThemeResource SystemControlBackgroundAltHighBrush}" CornerRadius="12">
                <StackPanel Spacing="15">
                    <FontIcon Glyph="&#xE7BA;" FontSize="50" Foreground="Red"/>
                    <TextBlock Text="Lakó jelentése" FontSize="18" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                    <TextBlock Text="Fegyelmi bejelentések" FontSize="12" Foreground="Gray" TextWrapping="Wrap" TextAlignment="Center"/>
                </StackPanel>
            </Button>
        </Grid>

        <Grid x:Name="GuestGrid" Grid.Row="1" Visibility="Collapsed">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="350"/>
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0" Padding="20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <AutoSuggestBox x:Name="GuestSearchBox" 
                                PlaceholderText="Keresés név vagy kártyaszám alapján..." 
                                QueryIcon="Find"
                                Margin="0,0,0,20"
                                TextChanged="GuestSearchBox_TextChanged"/>

                <ListView x:Name="GuestListView" Grid.Row="1" 
          Background="{ThemeResource SystemControlBackgroundAltHighBrush}"
          CornerRadius="8" Padding="10">
                    <ListView.Header>
                        <Grid Padding="12,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="180"/>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="180"/>
                                <ColumnDefinition Width="180"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Név" FontWeight="Bold" Grid.Column="0"/>
                            <TextBlock Text="Kártyaszám" FontWeight="Bold" Grid.Column="1"/>
                            <TextBlock Text="Szoba" FontWeight="Bold" Grid.Column="2"/>
                            <TextBlock Text="Belépés ideje" FontWeight="Bold" Grid.Column="3"/>
                            <TextBlock Text="Kilépés ideje" FontWeight="Bold" Grid.Column="4"/>
                        </Grid>
                    </ListView.Header>
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="local:GuestInfo">
                            <Grid Padding="5">
                                <Grid.ContextFlyout>
                                    <MenuFlyout>
                                        <MenuFlyoutItem Text="Kijelentkeztetés" 
                                    Click="MenuCheckout_Click" 
                                    Icon="LeaveChat"
                                    IsEnabled="{x:Bind CanCheckout, Mode=OneWay}"/>
                                        <MenuFlyoutItem Text="Újbóli felvétel (Másolás)" 
                                    Click="MenuReAdd_Click" 
                                    Icon="Refresh"
                                    IsEnabled="{x:Bind IsOut, Mode=OneWay}"/>
                                    </MenuFlyout>
                                </Grid.ContextFlyout>

                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="180"/>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="180"/>
                                    <ColumnDefinition Width="180"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Text="{x:Bind Name}" Grid.Column="0" VerticalAlignment="Center"/>
                                <TextBlock Text="{x:Bind CardId}" Grid.Column="1" VerticalAlignment="Center"/>
                                <TextBlock Text="{x:Bind Room}" Grid.Column="2" VerticalAlignment="Center"/>
                                <TextBlock Text="{x:Bind ArriveTime}" Grid.Column="3" VerticalAlignment="Center"/>
                                <TextBlock Text="{x:Bind LeaveTime, Mode=OneWay}" Grid.Column="4" VerticalAlignment="Center"/>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>

            <StackPanel Grid.Column="1" Background="{ThemeResource SystemControlBackgroundChromeMediumBrush}" Padding="20" Spacing="15">
                <TextBlock Text="Új vendég hozzáadása" FontSize="18" FontWeight="Bold" Margin="0,0,0,5"/>
                <TextBox x:Name="NameInput" Header="Név" PlaceholderText="Példa Béla"/>
                <TextBox x:Name="CardInput" Header="Kártyaszám" PlaceholderText="RFID ID"/>
                <TextBox x:Name="RoomInput" Header="Szobaszám" PlaceholderText="A/102"/>
                <TextBox x:Name="TimeInput" Header="Belépés ideje" IsReadOnly="True"/>
                <TextBox x:Name="LeaveTimeInput" Header="Kilépés ideje" IsReadOnly="True"/>
                <Button Content="Vendég rögzítése" Click="AddGuest_Click" 
                        Style="{StaticResource AccentButtonStyle}" HorizontalAlignment="Stretch" Margin="0,5,0,0"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>